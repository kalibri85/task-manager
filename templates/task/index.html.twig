{% extends 'base.html.twig' %}

{% block title %}Task list{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-4">Task Manager</h1>
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#taskModal">Create new task</button>
    </div>    
    {# Modal window to add a new task #}
    <div class="modal fade" id="taskModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Create New Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    {{ include('task/_form.html.twig', {form: form}) }} 
                </div>

            </div>
        </div>
    </div>   
    <div class="mb-3 d-flex align-items-center justify-content-between">
        {# Filtration form #}
        <form method="get" action="{{ path('app_task_index') }}" class="d-flex align-item-center gap-2">
            <select name="status" class="form-select w-auto">
                <option value="" {{ currentStatus is empty ? 'select' }}>
                    All    
                </option>
                <option value="pending" {{ currentStatus == 'pending' ? 'selected' }}>
                    Pending
                </option>
                <option value="in_progress" {{ currentStatus == 'in_progress' ? 'selected' }}>
                    In Progress
                </option>
                <option value="done" {{ currentStatus == 'done' ? 'selected' }}>
                    Done
                </option>
            </select>
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-funnel"></i> Filter
            </button> 
        </form>
        {# Switch for showing/hiding completed tasks #}
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="hideDoneSwitch" {{ hideDone ? 'checked' }} onchange="submitToggle()">
            <label class="form-check-label ms-2" for="hideDoneSwitch">
                Hide completed
            </label>    
        </div>      
    </div>
    {# Tasks list #}
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th>Due date/time</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for task in tasks %}
            <tr class="{% if task.dueDate and task.dueDate|date('U') < 'now'|date('U') and task.status != 'done' %}table-danger{% endif %}">
                <td>{{ task.id }}</td>
                <td>{{ task.title }}</td>
                <td>{{ task.description }}</td>
                <td>
                    {% if task.status == 'done' %}
                        <span class="badge bg-success">Done</span>
                    {% elseif task.status == 'in_progress' %}
                        <span class="badge bg-primary">In Progress</span>
                    {% else %}
                        <span class="badge bg-warning text-dark">Pending</span>
                    {% endif %}           
                </td>
                <td>{{ task.dueDate ? task.dueDate|date('Y-m-d H:i') : '' }}</td>
                <td>
                    <a href="{{ path('app_task_show', {'id': task.id}) }}" class="btn btn-secondary btn-sm me-1"><i class="bi bi-eye"></i> Show</a>
                    <button class="btn btn-secondary btn-sm me-1 edit-task-btn" data-url="{{ path('app_task_edit', {'id': task.id} )}}"><i class="bi bi-pencil"></i> Edit</button>

                    {{ include('task/_delete_form.html.twig', {button_class: 'btn btn-danger btn-sm me-1'}) }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="mt-4 d-flex justify-content-center">
        {{ knp_pagination_render(tasks, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
    </div>
    <div class="modal-footer justify-content-end">
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#taskModal">Create new task</button>
    </div> 

     {# Modal window to edit a task #}   
     <div class="modal fade" id="editTaskModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editTaskContent">
                    Loading...
                </div>
            </div>
        </div>
     </div>
{% endblock %}
